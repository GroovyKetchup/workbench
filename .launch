<stringAttribute key="org.eclipse.jdt.launching.MAIN_TYPE" value="$MAIN_TYPE$"/>
<stringAttribute key="org.eclipse.jdt.launching.VM_ARGUMENTS" value="$VM_ARGUMENTS$"/>
<stringAttribute key="org.eclipse.jdt.launching.PROGRAM_ARGUMENTS" value="$PROGRAM_ARGUMENTS$"/>
</launchConfiguration>
